{
  "name": "healthcare-appointment-backend",
  "version": "1.0.0",
  "description": "Healthcare Appointment & Follow-up Manager — Backend API",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/app.js",
    "start": "node src/app.js",
    "worker": "node src/jobs/worker.js",
    "prisma:generate": "npx prisma generate --schema=src/prisma/schema.prisma",
    "prisma:migrate": "npx prisma migrate deploy --schema=src/prisma/schema.prisma",
    "prisma:studio": "npx prisma studio --schema=src/prisma/schema.prisma",
    "seed": "npx prisma db seed --schema=src/prisma/schema.prisma"
  },
  "dependencies": {
    "@mistralai/mistralai": "^1.5.0",
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "googleapis": "^148.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.10.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  }
}
